CONTRIBUTING.md
SECURITY.md
al-development.md

# Test files
*.test.js
test/
tests/

# Nested node_modules in tools
tools/aldc-validate/node_modules/

# Source pack files (already copied to target locations)
bcagentpack/

# Pack .tgz files
*.tgz
